{
    "name": "@tak-ps/node-p12",
    "version": "1.0.2",
    "description": "Extracts the certificate and the private key from a p12/ pkcs12 file",
    "type": "module",
    "main": "lib/index.js",
    "types": "lib/index.d.ts",
    "exports": {
        ".": {
            "types": "./lib/index.d.ts",
            "import": "./lib/index.js"
        }
    },
    "scripts": {
        "test": "tsx --test tests/**/*.test.ts",
        "build": "tsc",
        "prepack": "npm run build",
        "doc": "typedoc index.ts",
        "lint": "eslint src tests"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/dfpc-coe/node-p12.git"
    },
    "keywords": [
        "p12",
        "cert",
        "pem",
        "private key",
        "p12 to pem",
        "concert p12",
        "extract p12"
    ],
    "license": "ISC",
    "files": [
        "lib/**/*"
    ],
    "engines": {
        "node": ">=24"
    },
    "homepage": "https://github.com/dfpc-coe/node-p12#readme",
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.0.0",
        "@types/node-forge": "^1.3.0",
        "eslint": "^10.0.0",
        "tsx": "^4.21.0",
        "typedoc": "^0.28.18",
        "typescript": "^6.0.0",
        "typescript-eslint": "^8.0.0"
    },
    "dependencies": {
        "node-forge": "^1.4.0"
    }
}
